{
  "name": "bibot-auth",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "auth:migrate": "npx auth@latest migrate --config ./src/lib/auth.ts --yes"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "better-auth": "^1.3.6",
    "hono": "^4.6.12",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.11",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}

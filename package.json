{
  "name": "bibot-auth",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "auth:migrate": "npx auth@latest migrate --config ./src/lib/auth.ts --yes",
    "test:db:prepare": "tsx test/helpers/ensure-test-db.ts && DATABASE_URL=postgres://postgres:postgres@localhost:5432/bibot_auth_test npm run auth:migrate",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@scalar/hono-api-reference": "^0.10.8",
    "better-auth": "^1.3.6",
    "hono": "^4.6.12",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.11",
    "@vitest/coverage-v8": "^4.1.4",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.4"
  }
}
